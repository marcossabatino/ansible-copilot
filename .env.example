# ═══════════════════════════════════════════════════════════
# ansible-copilot — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA comite o arquivo .env no Git.
# ═══════════════════════════════════════════════════════════

# ─── Anthropic API ─────────────────────────────────────────
# Obtenha sua chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LiteLLM ───────────────────────────────────────────────
# Senha master para o proxy LiteLLM (escolha uma senha forte)
LITELLM_MASTER_KEY=sk-local-CHANGE_ME_TO_RANDOM_STRING

# Budget mensal em USD (alertas em 80%)
LITELLM_MAX_BUDGET=50

# ─── Open WebUI ────────────────────────────────────────────
# Chave secreta para sessões (gere com: openssl rand -hex 32)
WEBUI_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING

# Desabilitar cadastro público (single-user)
ENABLE_SIGNUP=false

# ─── Ollama (fase futura) ──────────────────────────────────
# Descomente quando adicionar Ollama
# OLLAMA_BASE_URL=http://ollama:11434
